# Google OAuth (crear en Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URL a la que redirige después del login exitoso (Quasar dev suele ser 9000)
FRONTEND_REDIRECT_URL=http://localhost:9000/#/

# JWT
JWT_SECRET=change-me
JWT_TTL_MINUTES=10080

# Cookie (dev)
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# CORS (si NO usas proxy /api)
CORS_ORIGINS=http://localhost:9000

# Backend
HOST=127.0.0.1
PORT=8000
